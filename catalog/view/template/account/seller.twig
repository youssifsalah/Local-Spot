{{ header }}
<div id="account-seller" class="container">
  <nav class="modern-breadcrumb-wrap" aria-label="Breadcrumb">
    <ol class="modern-breadcrumb">
      {% for breadcrumb in breadcrumbs %}
        <li class="modern-breadcrumb-item{% if loop.last %} is-current{% endif %}">
          {% if loop.last %}
            <span class="modern-breadcrumb-link" aria-current="page">{{ breadcrumb.text }}</span>
          {% else %}
            <a href="{{ breadcrumb.href }}" class="modern-breadcrumb-link">{{ breadcrumb.text }}</a>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
  <div class="row">
    {{ column_left }}
    <div id="content" class="col">
      {{ content_top }}
      {% if success %}
        <div class="alert alert-success alert-dismissible"><i class="fa-solid fa-circle-check"></i> {{ success }} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      {% endif %}
      {% if error %}
        <div class="alert alert-danger alert-dismissible"><i class="fa-solid fa-circle-exclamation"></i> {{ error }} <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
      {% endif %}

      <div class="register-shell">
        <div class="register-panel register-modern-card">
          <h1 class="register-modern-title">{{ heading_title }}</h1>

          <form action="{{ brand_save }}" method="post" enctype="multipart/form-data" class="register-modern-form mb-4">
            <fieldset>
              <legend>{{ text_brand }}</legend>
              <div class="row mb-3 required">
                <label for="input-brand-name" class="col-sm-2 col-form-label">{{ entry_brand_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="brand_name" value="{{ brand_name }}" id="input-brand-name" class="form-control" placeholder="{{ entry_brand_name }}"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-brand-logo" class="col-sm-2 col-form-label">{{ entry_brand_logo }}</label>
                <div class="col-sm-10">
                  <input type="file" name="brand_logo" id="input-brand-logo" class="form-control"/>
                  {% if brand_image %}
                    <small class="text-muted">Current: {{ brand_image }}</small>
                  {% endif %}
                </div>
              </div>
              <div class="row mb-3 required">
                <label for="input-brand-gender" class="col-sm-2 col-form-label">{{ entry_brand_gender }}</label>
                <div class="col-sm-10">
                  <select name="brand_gender" id="input-brand-gender" class="form-select">
                    <option value="">{{ text_select }}</option>
                    {% for key, label in gender_options %}
                      <option value="{{ key }}"{% if brand_gender == key %} selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="text-end">
                <button type="submit" class="btn btn-primary">{{ button_save_brand }}</button>
              </div>
            </fieldset>
          </form>

          <form action="{{ product_save }}" method="post" enctype="multipart/form-data" class="register-modern-form">
            <fieldset>
              <legend>{{ text_product }}</legend>
              <div class="row mb-3 required">
                <label for="input-product-name" class="col-sm-2 col-form-label">{{ entry_product_name }}</label>
                <div class="col-sm-10">
                  <input type="text" name="product_name" id="input-product-name" class="form-control" placeholder="{{ entry_product_name }}"/>
                </div>
              </div>
              <div class="row mb-3 required">
                <label for="input-product-price" class="col-sm-2 col-form-label">{{ entry_product_price }}</label>
                <div class="col-sm-10">
                  <input type="number" step="0.01" name="product_price" id="input-product-price" class="form-control" placeholder="{{ entry_product_price }}"/>
                </div>
              </div>
              <div class="row mb-3 required">
                <label for="input-product-category" class="col-sm-2 col-form-label">{{ entry_product_category }}</label>
                <div class="col-sm-10">
                  <select name="category_id" id="input-product-category" class="form-select">
                    <option value="0">{{ text_select }}</option>
                    {% for category in categories %}
                      <option value="{{ category.category_id }}">{{ category.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-product-image" class="col-sm-2 col-form-label">{{ entry_product_image }}</label>
                <div class="col-sm-10">
                  <input type="file" name="product_image" id="input-product-image" class="form-control"/>
                </div>
              </div>
              <div class="row mb-3">
                <label for="input-product-description" class="col-sm-2 col-form-label">{{ entry_product_description }}</label>
                <div class="col-sm-10">
                  <textarea name="product_description" id="input-product-description" rows="5" class="form-control" placeholder="{{ entry_product_description }}"></textarea>
                </div>
              </div>
              <div class="text-end">
                <button type="submit" class="btn btn-primary">{{ button_save_product }}</button>
              </div>
            </fieldset>
          </form>
        </div>
      </div>
      {{ content_bottom }}
    </div>
    {{ column_right }}
  </div>
</div>
{{ footer }}
