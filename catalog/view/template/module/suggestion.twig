{{ header }}
<div id="content" class="container">
  <h1>{{ heading_title }}</h1>

  {% if products %}
    <div class="row">
      {% for product in products %}
        <div class="col-md-3">
          <div class="card mb-3">
            <a href="{{ product.href }}">
              <img src="{{ product.thumb }}" alt="{{ product.name }}" class="card-img-top"/>
            </a>
            <div class="card-body">
              <h5 class="card-title">{{ product.name }}</h5>
              <p class="card-text">{{ product.price }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p>{{ text_empty }}</p>
  {% endif %}
</div>
{{ footer }}