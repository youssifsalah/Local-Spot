<div id="recommendation-module" class="container my-4">
  <h3>{{ heading_title }}</h3>

  {% if products %}
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-4">
      {% for product in products %}
        <div class="col mb-3">{{ product }}</div>
      {% endfor %}
    </div>
  {% else %}
    <p>{{ text_no_products }}</p>
  {% endif %}
</div>
     