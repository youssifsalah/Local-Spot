  <header>
<nav class="navbar navbar-expand-lg px-3 px-lg-5 py-0 site-main-nav">
  <div class="container-fluid site-main-nav-inner">

    <!-- LEFT: Toggler + Menu -->
    <div class="site-main-left d-flex align-items-center">

      <!-- Toggler -->
      <button class="navbar-toggler me-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarText">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Collapsible Menu -->
      <div class="collapse navbar-collapse site-main-collapse" id="navbarText">
        <ul class="navbar-nav nav nav-underline mb-2 mb-lg-0 text-center">
          <li class="nav-item">
  <a href="{{ home }}"
     class="nav-link {% if route == 'common/home' %}active{% endif %}">
     {{ text_home }}
  </a>
</li>
         <li class="nav-item">
        <a href="{{ contact }}" class="nav-link {% if route == 'information/contact' %}active{% endif %}">{{ text_contact }}</a>
      </li>

      {% if logged %}
      <li class="nav-item">
  <a href="{{ suggestion }}"
     class="nav-link {% if route == 'account/suggestion' %}active{% endif %}">
     {{ text_suggestion }}
  </a>
</li>
      <li class="nav-item">
        <a href="{{ order }}" class="nav-link {% if route == 'account/order' %}active{% endif %}">{{ text_order }}</a>
      </li>

   
      {% endif %}

      {% if not logged %}

      <li class="nav-item">
        <a href="{{ register }}" class="nav-link">{{ text_register }}</a>
      </li>
      <li class="nav-item">
        <a href="{{ login }}" class="nav-link">{{ text_login }}</a>
      </li>
      {% else %}

    
      {% endif %}
    </ul>

      </div>

    </div>

    <!-- CENTER: Logo (ABSOLUTE → True center) -->
    <div class="site-main-logo">
      <a href="{{ home }}">
        <img src="{{ logo }}" alt="{{ name }}" class="logo1">
      </a>
    </div>

    <!-- RIGHT: Icons -->
    <ul class="nav d-flex align-items-center site-main-actions">
      {% if logged and is_seller %}
      <li class="nav-item me-2">
        <a href="{{ seller_dashboard }}" class="btn btn-outline-dark rounded-pill px-3 py-1 {% if route == 'account/seller' %}active{% endif %}">{{ text_dashboard }}</a>
      </li>
      {% endif %}
      <li class="nav-item"><a href="{{ wishlist }}" class="nav-link text-black"><i class="fa-regular fa-heart"></i></a></li>
      <li class="nav-item">{{ cart }}</li>
      <li class="nav-item dropdown">
        <a href="#"
           class="nav-link text-black dropdown-toggle account-menu-toggle"
           data-bs-toggle="dropdown"
           aria-expanded="false">
          <i class="fa-regular fa-user"></i>
        </a>
        <ul class="dropdown-menu dropdown-menu-end account-menu-dropdown">
          {% if logged %}
            <li><a class="dropdown-item account-menu-item" href="{{ account }}">{{ text_account }}</a></li>
            <li><a class="dropdown-item account-menu-item" href="{{ order }}">{{ text_order }}</a></li>
            <li><a class="dropdown-item account-menu-item account-menu-logout" href="{{ logout }}">{{ text_logout }}</a></li>
          {% else %}
            <li><a class="dropdown-item account-menu-item" href="{{ login }}">{{ text_login }}</a></li>
            <li><a class="dropdown-item account-menu-item" href="{{ register }}">{{ text_register }}</a></li>
          {% endif %}
        </ul>
      </li>
    </ul>

  </div>
</nav>
 



 

   
