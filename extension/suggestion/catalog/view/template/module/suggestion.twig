<div id="content" class="container">
  <h1 class="Ft" >{{ heading_title }}</h1>

  {% if products %}
    <div class="row " style="margin-top:50px;">
      {% for product in products %}
      <div class="col mb-3 mt-5">{{ product }}</div>
      {% endfor %}
    </div>
  {% else %}
    <p>{{ text_empty }}</p>
  {% endif %}
</div>
